{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Articles and news content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "readTime": {
      "type": "string"
    },
    "embedUrl": {
      "type": "string"
    },
    "embedType": {
      "type": "enumeration",
      "enum": ["iframe", "script", "oembed"]
    },
    "source": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["Pergerakan Kurs", "Edukasi", "Analisis Pasar", "Tips & Tricks", "Regulasi"],
      "required": true
    },
    "publishedDate": {
      "type": "date",
      "required": true
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "thumbnailUrl": {
      "type": "string"
    },
    "isEmbed": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "enumeration",
      "enum": ["draft", "published", "archived"],
      "default": "draft"
    }
  }
}
