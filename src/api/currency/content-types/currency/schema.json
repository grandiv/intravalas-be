{
  "kind": "collectionType",
  "collectionName": "currencies",
  "info": {
    "singularName": "currency",
    "pluralName": "currencies",
    "displayName": "Currency",
    "description": "Currency exchange rates"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "buyRate": {
      "type": "decimal",
      "required": true
    },
    "sellRate": {
      "type": "decimal",
      "required": true
    },
    "middleRate": {
      "type": "decimal",
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "source": {
      "type": "string",
      "required": true
    },
    "changePercentage": {
      "type": "decimal",
      "default": 0
    },
    "notes": {
      "type": "text"
    }
  }
}
